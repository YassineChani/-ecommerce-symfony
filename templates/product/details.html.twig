{% extends 'base.html.twig' %}

{% block title %}{{ product.name }} - Details - Our Store{% endblock %}

{% block body %}
    <div class="container my-5">
        <div class="row">
            <div class="col-md-6 text-center">
                {% if product.image %}
                    <img src="{{ asset('images/' ~ product.image) }}" class="img-fluid rounded shadow-sm p-4 bg-light" alt="{{ product.name }}" style="max-height: 450px; object-fit: contain;">
                {% else %}
                    <img src="{{ asset('images/airbod.png') }}" class="img-fluid rounded shadow-sm p-4 bg-light" alt="{{ product.name }}" style="max-height: 450px; object-fit: contain;">
                {% endif %}
            </div>

            <div class="col-md-6">
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a href="{{ path('app_categories') }}" class="text-decoration-none">Home</a></li>
                        <li class="breadcrumb-item"><a href="{{ path('app_category_products', { id: product.category.id }) }}" class="text-decoration-none">{{ product.category.name }}</a></li>
                        <li class="breadcrumb-item active" aria-current="page">{{ product.name }}</li>
                    </ol>
                </nav>

                <span class="badge bg-primary mb-3">{{ product.category.name }}</span>
                {% if product.isTop %}
                    <span class="badge bg-warning text-dark mb-3">TOP Product</span>
                {% endif %}
                
                <h1 class="mb-3 fw-bold">{{ product.name }}</h1>
                
                <h3 class="text-success fw-bold mb-4">${{ product.price|number_format(2) }}</h3>

                <div class="mb-4">
                    <h5 class="fw-semibold">Description</h5>
                    <p class="text-muted leading-relaxed">
                        {{ product.description }}
                    </p>
                </div>

                <form action="{{ path('app_cart_add', { id: product.id }) }}" method="post">
                    <div class="mb-3">
                        <label for="quantity" class="form-label fw-semibold">Quantity</label>
                        <input type="number" class="form-control" id="quantity" name="quantity" value="1" min="1" max="10" style="max-width: 100px;">
                    </div>

                    <div class="d-grid gap-2 d-md-flex">
                        <button type="submit" class="btn btn-primary btn-lg px-5">Add to Cart</button>
                        <a href="{{ path('app_products') }}" class="btn btn-outline-secondary btn-lg">Continue Shopping</a>
                    </div>
                </form>

                <div class="mt-4 pt-4 border-top">
                    <ul class="list-unstyled">
                        <li class="mb-2"><strong>SKU:</strong> STORE-{{ product.id|format('%03d') }}</li>
                        <li class="mb-2"><strong>Availability:</strong> <span class="text-success">In Stock</span></li>
                        <li class="mb-2"><strong>Category:</strong> {{ product.category.name }}</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
