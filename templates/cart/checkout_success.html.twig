{% extends 'base.html.twig' %}

{% block title %}Checkout Success - Our Store{% endblock %}

{% block body %}
    <div class="container my-5 text-center">
        <div class="card shadow-sm border-0 bg-light-subtle p-5 mx-auto" style="max-width: 600px;">
            <div class="mb-4">
                <svg xmlns="http://www.w3.org/2000/svg" width="80" height="80" fill="currentColor" class="bi bi-check-circle-fill text-success" viewBox="0 0 16 16">
                    <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0m-3.97-3.03a.75.75 0 0 0-1.08.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-.01-1.05z"/>
                </svg>
            </div>
            
            <h1 class="display-5 fw-bold mb-3 text-success">Panier enregistré !</h1>
            <p class="lead text-muted mb-4">Your order has been recorded successfully. You can track its status under your Profile.</p>
            
            <div class="card text-start mb-4 border-0 bg-body">
                <div class="card-body">
                    <h5 class="fw-semibold mb-3 border-bottom pb-2">Order Summary</h5>
                    <p class="mb-2"><strong>Order ID:</strong> #{{ order.id }}</p>
                    <p class="mb-2"><strong>Date:</strong> {{ order.createdAt|date('Y-m-d H:i:s') }}</p>
                    <p class="mb-2"><strong>Status:</strong> <span class="badge bg-success">{{ order.status }}</span></p>
                    
                    <h6 class="fw-semibold mt-3">Items:</h6>
                    <ul class="list-group list-group-flush mb-0">
                        {% for item in order.orderItems %}
                            <li class="list-group-item d-flex justify-content-between align-items-center bg-transparent px-0 py-2">
                                <div>
                                    {{ item.product.name }}
                                    <span class="text-muted">x {{ item.quantity }}</span>
                                </div>
                                <span class="fw-semibold">${{ (item.price * item.quantity)|number_format(2) }}</span>
                            </li>
                        {% endfor %}
                    </ul>
                </div>
            </div>
            
            <div class="d-grid gap-2 d-md-flex justify-content-center">
                <a href="{{ path('app_profile') }}" class="btn btn-primary px-4 btn-lg">Go to My Profile</a>
                <a href="{{ path('app_products') }}" class="btn btn-outline-secondary px-4 btn-lg">Back to Store</a>
            </div>
        </div>
    </div>
{% endblock %}
